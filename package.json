{
  "name": "orions-belt",
  "private": true,
  "version": "0.0.0",
  "description": "Orion's Belt -- generative AI website builder for Rent Manager. Monorepo root.",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "test": "pnpm --filter web test",
    "test:e2e": "pnpm --filter web test:e2e",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter web typecheck",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --linked > apps/web/types/database.ts",
    "seed": "supabase db reset --linked",
    "record-fixtures": "tsx apps/web/scripts/record-fixtures.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "tsx": "4.20.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "@tailwindcss/oxide",
      "esbuild",
      "rolldown",
      "sharp",
      "unrs-resolver"
    ]
  }
}
