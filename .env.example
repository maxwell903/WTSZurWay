# Orion's Belt — environment template.
#
# Copy this file to apps/web/.env.local and fill in the five values from
# Supabase Project Settings -> API/General and the Anthropic console.
# NEVER commit a populated copy of this file.

# Hosted Supabase project URL (e.g. https://abcdef.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Anon public key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only. Bypasses RLS. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=

# The project ref segment from your Supabase URL (the "abcdef" above).
SUPABASE_PROJECT_REF=

# Anthropic API key — server-only, never exposed to the browser.
# Used by Sprint 4's /api/generate-initial-site and later AI surfaces.
ANTHROPIC_API_KEY=
