# Hosted Supabase project (per /DECISIONS.md 2026-04-25 — supersedes PROJECT_SPEC.md §3.4 local Docker setup)
# Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Project Settings -> API -> anon public key (safe for client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Project Settings -> API -> service_role key (SERVER ONLY -- bypasses RLS, never ship to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Project Settings -> General -> Project Ref (used by `supabase link` and `pnpm db:types`)
SUPABASE_PROJECT_REF=

# Anthropic API key (server-side only; first used in Sprint 4)
ANTHROPIC_API_KEY=
